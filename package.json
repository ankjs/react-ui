{
  "name": "@ankjs/react-ui",
  "version": "1.0.5",
  "description": "React User Interface Components",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "scripts": {
    "prepare": "npm run build",
    "prepublishOnly": "npm run test && npm run prettier && npm run lint",
    "build": "npm run build:esm && npm run build:cjs",
    "build:esm": "tsc",
    "build:cjs": "tsc --module commonjs --outDir dist/cjs",
    "test": "jest --config jestconfig.json",
    "lint": "eslint \"{**/*,*}.{js,ts,jsx,tsx}\"",
    "prettier": "prettier --write \"{src,tests,example/src}/**/*.{js,ts,jsx,tsx}\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ankjs/react-ui.git"
  },
  "peerDependencies": {
    "react": ">=16"
  },
  "author": "@ankjs",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ankjs/react-ui/issues"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "react",
    "react-ui",
    "react user interface",
    "ankjs ui",
    "@ankjs/react-ui"
    
  ],
  "homepage": "https://github.com/ankjs/react-ui#readme",
  "dependencies": {
    "@testing-library/react": "^16.0.0",
    "@types/jest": "^29.5.12",
    "@types/react": "^18.3.3",
    "@typescript-eslint/eslint-plugin": "^7.15.0",
    "@typescript-eslint/parser": "^7.15.0",
    "ankhema": "^1.0.8",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-react": "^7.34.3",
    "eslint-plugin-react-hooks": "^4.6.2",
    "jest": "^29.7.0",
    "jest-canvas-mock": "^2.5.2",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.3.2",
    "react": ">=16",
    "react-dom": "^18.3.1",
    "ts-jest": "^29.1.5",
    "tslib": "^2.8.1",
    "typescript": "^5.5.3"
  }
}
